  "jobTitle": "Writer and Graphic Designer",
  "description": "Author of The Light Inside the Tunnel — A Philosophy for the Human Heart. Graphic designer at Skylight Designs, Ottawa, Canada.",
  "sameAs": [
    "https://skylightdesigns.ca"
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ottawa",
    "addressRegion": "ON",
    "addressCountry": "CA"
  },
  "knowsAbout": ["Consistencialism", "Philosophy", "Graphic Design"]
}
</script>
{% endblock %}

{% block newsletter %}{% endblock %}
